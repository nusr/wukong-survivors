{
  "name": "wukong-survivors",
  "version": "1.0.0",
  "description": "Wukong Survivors game built with Phaser.js + Vite + React",
  "type": "module",
  "scripts": {
    "start": "vite --host",
    "build": "vite build",
    "type-check": "tsc",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest run --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "lint": "npx oxlint@latest",
    "lint:fix": "npx oxlint@latest --fix",
    "prepare": "husky"
  },
  "keywords": [
    "phaser",
    "game",
    "survivors",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/react": "^10.66.0",
    "i18next": "^26.3.6",
    "lodash": "^4.18.1",
    "phaser": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "canvas": "^3.2.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "packageManager": "yarn@1.22.22"
}
